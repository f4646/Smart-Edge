<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/section_interaction"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="?attr/colorOnSurface" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:id="@+id/interactionScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/app_screen_padding">

            <com.google.android.material.card.MaterialCardView
                style="@style/App_Card_Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_gestures" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/edge_gestures" android:textColor="?attr/colorOnSurface" />
                    
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_only_on_home" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/only_on_home" android:textColor="?attr/colorOnSurface" android:layout_marginTop="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/only_on_home_desc" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp" />

                    <LinearLayout 
                        android:id="@+id/layout_swipe_sensitivity"
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:orientation="vertical" 
                        android:layout_marginTop="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/edge_sensitivity" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="12sp" />
                            <TextView android:id="@+id/tvSwipeSensitivityValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50%" android:textColor="?attr/colorPrimary" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                        <com.google.android.material.slider.Slider style="@style/Widget.App.Slider"
                            android:id="@+id/sbSwipeSensitivity" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="1.0" android:valueTo="100.0" android:value="50.0" app:tickVisible="false" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginVertical="16dp" />

                    <LinearLayout
                        android:id="@+id/layoutTapGestures"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tap_gestures"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvTapGesturesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/tap_gestures_desc"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginVertical="16dp" />

                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_haptic" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/haptic_feedback" android:textColor="?attr/colorOnSurface" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION: Notch Gestures -->
            <TextView
                style="@style/App_SectionTitle"
                android:text="@string/notch_gestures" />

            <com.google.android.material.card.MaterialCardView
                style="@style/App_Card_Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_notch_gestures" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/enable_notch_gestures" android:textColor="?attr/colorOnSurface" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/notch_gestures_desc" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginVertical="16dp" />

                    <LinearLayout
                        android:id="@+id/layoutNotchTapGestures"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/notch_tap_gestures"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvNotchTapGesturesValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Disabled"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SECTION: Slide Brightness -->
            <TextView
                style="@style/App_SectionTitle"
                android:text="@string/edge_seek_title" />

            <com.google.android.material.card.MaterialCardView
                style="@style/App_Card_Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/edge_seek_desc" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp" />

                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_slide_brightness" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/slide_brightness" android:textColor="?attr/colorOnSurface" />
                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_slide_volume" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/slide_volume" android:textColor="?attr/colorOnSurface" />

                    <LinearLayout 
                        android:id="@+id/layoutSlideSensitivity"
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:orientation="vertical" 
                        android:layout_marginTop="16dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/seek_sensitivity" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="12sp" />
                            <TextView android:id="@+id/tvSlideSensitivityValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50%" android:textColor="?attr/colorPrimary" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                        <com.google.android.material.slider.Slider style="@style/Widget.App.Slider"
                            android:id="@+id/sbSlideSensitivity" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="1.0" android:valueTo="100.0" android:value="50.0" app:tickVisible="false" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/App_SectionTitle"
                android:text="Multitasking &amp; Windowing" />

            <com.google.android.material.card.MaterialCardView
                style="@style/App_Card_Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_drag_split" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Drag to Split-Screen" android:textColor="?attr/colorOnSurface" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Drag icons to top/bottom edge to launch in split mode" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginVertical="16dp" />

                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_freeform" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Freeform Window Mode" android:textColor="?attr/colorOnSurface" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Launch apps in floating windows (Requires system support)" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp" />

                    <!-- Window size mode picker — only visible when freeform is ON -->
                    <LinearLayout
                        android:id="@+id/layout_freeform_size"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Window Size"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvFreeformSizeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Standard (80%)"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/App_SectionTitle"
                android:text="Screen Edge Side" />

            <com.google.android.material.card.MaterialCardView
                style="@style/App_Card_Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/togglePanelSide"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSideLeft"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Left" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSideRight"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Right" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/App_SectionTitle"
                android:text="@string/section_advanced_options" />

            <com.google.android.material.card.MaterialCardView
                style="@style/App_Card_Section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    style="@style/App_CardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_automation_gestures" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/automation_title" android:textColor="?attr/colorOnSurface" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/automation_desc" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginVertical="16dp" />

                    <LinearLayout
                        android:id="@+id/layoutFullscreenWhitelist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/fullscreen_protection"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/fullscreen_desc"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvFullscreenWhitelistValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 apps selected"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginVertical="12dp" />

                    <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/feature_gameMode" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/game_mode" android:textColor="?attr/colorOnSurface" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/game_mode_desc" android:textColor="?attr/colorOnSurfaceVariant" android:textSize="11sp" />

                    <LinearLayout
                        android:id="@+id/layoutGameApps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="8dp"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvGameAppsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 apps selected"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
